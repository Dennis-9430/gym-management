          },
          "voucherImage": "Imagen del comprobante (base64)",
          "status": {
            "tipo": "enum",
            "valores": ["PENDING", "CONFIRMED", "REJECTED"],
            "default": "PENDING"
          },
          "createdAt": "Fecha de creación",
          "confirmedAt": "Fecha de confirmación (nullable)",
          "confirmedBy": "Admin que confirmó (nullable)"
        },
        "endpoints_propuestos": {
          "create": "POST /api/payments - Subir comprobante",
          "list": "GET /api/payments - Listar pagos pendientes",
          "confirm": "PUT /api/payments/{payment_id}/confirm - Admin confirma",
          "reject": "PUT /api/payments/{payment_id}/reject - Admin rechaza"
        }
      }
    },

