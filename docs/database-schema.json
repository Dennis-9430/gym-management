  "flujo_registro": {
    "descripcion": "Flujo para crear un nuevo tenant (gimnasio)",
    "pasos": [
      {
        "step": 1,
        "accion": "Usuario visita /register",
        "frontend": "Selecciona plan (BASIC o PREMIUM)"
      },
      {
        "step": 2,
        "accion": "Completa formulario",
        "campos": ["email", "password", "businessName", "businessPhone"]
      },
      {
        "step": 3,
        "accion": "POST /api/tenants/register",
        "backend": {
          "action": "Crea tenant con subscriptionStatus: PENDING",
          "tenantId": "Genera UUID único",
          "plan": "BASIC o PREMIUM según selección"
        }
      },
      {
        "step": 4,
        "accion": "Redirecciona a /login",
        "mensaje": "Cuenta creada,falta confirmar pago"
      },
      {
        "step": 5,
        "accion": "Usuario inicia sesión",
        "nota": "Ve panel pero con limitaciones",
        "propuesta": "Muestra banner 'Esperando confirmación de pago'"
      },
      {
        "step": 6,
        "accion": "Usuario sube comprobante",
        "propuesta": "POST /api/payments (nuevo endpoint)",
        "resultado": "Crea registro en payments con status: PENDING"
      },
      {
        "step": 7,
        "accion": "Admin revisa pago",
        "propuesta": "PUT /api/payments/{id}/confirm",
        "resultado": "payments.status: CONFIRMED, tenant.subscriptionStatus: ACTIVE"
      }
    ]
  },

