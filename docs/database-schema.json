  "colecciones": {
    "tenants": {
      "descripcion": "Gimnasios/Empresas que usan el sistema",
      "existente": true,
      "ruta": "/api/tenants",
      "campos": {
        "_id": "ObjectId",
        "tenantId": "UUID único del tenant",
        "email": "Email del administrador (único)",
        "password": "Hash bcrypt",
        "businessName": "Nombre del gimnasio",
        "businessPhone": "Teléfono de contacto",
        "businessAddress": "Dirección física",
        "businessRuc": "RUC/CI",
        "plan": {
          "tipo": "enum",
          "valores": ["BASIC", "PREMIUM"]
        },
        "subscriptionStatus": {
          "tipo": "enum",
          "valores": ["PENDING", "ACTIVE", "EXPIRED", "CANCELLED"],
          "default": "PENDING"
        },
        "subscriptionEndDate": "Fecha fin de suscripción (nullable)",
        "taxRate": "Tasa de impuesto (default: 12.0)",
        "currency": "Moneda (default: USD)",
        "openingHour": "Hora de apertura (default: 06:00)",
        "closingHour": "Hora de cierre (default: 22:00)",
        "wsspReminderDays": "Días para recordatorio WhatsApp (default: 3)",
        "wsspEnabled": "WhatsApp activo (default: false)",
        "createdAt": "Fecha de creación",
        "updatedAt": "Última actualización"
      },
      "relaciones": {
        "employees": "tenantId -> employees.tenantId",
        "clients": "tenantId -> clients.tenantId",
        "services": "tenantId -> services.tenantId",
        "products": "tenantId -> products.tenantId",
        "sales": "tenantId -> sales.tenantId",
        "invoices": "tenantId -> invoices.tenantId",
        "attendance": "tenantId -> attendance.tenantId"
