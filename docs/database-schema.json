        "subtotal": "Subtotal total",
        "tax": "Impuesto",
        "total": "Total final",
        "payment": {
          "method": {
            "tipo": "enum",
            "valores": ["CASH", "TRANSFER", "DEPOSIT", "MIXED"]
          },
          "cashAmount": "Monto en efectivo",
          "transferAmount": "Monto en transferencia",
          "depositAmount": "Monto en depósito",
          "voucherCode": "Código del comprobante",
          "voucherImage": "Imagen del comprobante (base64)"
        },
        "status": {
          "tipo": "enum",
          "valores": ["COMPLETED", "CANCELLED", "REFUNDED"],
          "default": "COMPLETED"
        },
        "createdAt": "Fecha de creación"
      },
      "indice": ["tenantId", "createdAt"],
      "endpoints": {
        "list": "GET /api/sales",
        "get": "GET /api/sales/{sale_id}",
        "create": "POST /api/sales",
        "delete": "DELETE /api/sales/{sale_id}",
        "update_voucher": "PUT /api/sales/{sale_id}/voucher",
        "verify": "PUT /api/sales/{sale_id}/verify"
      }
